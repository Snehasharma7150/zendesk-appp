# ── Salesforce Connected App ──────────────────────────────────────────
SF_CLIENT_ID=YOUR_SALESFORCE_CONSUMER_KEY
SF_CLIENT_SECRET=YOUR_SALESFORCE_CONSUMER_SECRET

# Must exactly match the Callback URL registered in your Salesforce Connected App
SF_REDIRECT_URI=https://your-app.up.railway.app/auth/salesforce/callback

# Use https://test.salesforce.com for a Sandbox org
SF_LOGIN_URL=https://login.salesforce.com

SF_API_VERSION=v59.0

# ── Server ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Security ──────────────────────────────────────────────────────────
# Random secret used to sign the OAuth state param. Generate with:
#   openssl rand -hex 32
STATE_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING
